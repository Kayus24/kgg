#!/bin/sh
set -eu

changed="$(git diff --cached --name-only --diff-filter=ACMR)"
if ! printf '%s\n' "$changed" | grep -Eq '^(\.githooks/pre-commit$|kgg-update/src/|kgg-update/version\.json$|release-pipeline/(build_therapist_source|kgg_selftest_build|kgg_test_battery|kgg_ui_contract[^/]*|kgg_new_patch|kgg_export_handoff|test_kgg_selftest_build)\.)'; then
  exit 0
fi

echo "KGG pre-commit: vollständige lokale Zertifizierung ..."
if command -v python >/dev/null 2>&1; then
  python release-pipeline/kgg_selftest_build.py --certify
elif command -v py >/dev/null 2>&1; then
  py -3 release-pipeline/kgg_selftest_build.py --certify
else
  echo "FEHLER: Python wurde nicht gefunden; Commit wird blockiert." >&2
  exit 1
fi
